"""Per-user audio stream capture from Discord voice channels.

Subclasses py-cord's Sink to intercept per-user PCM data,
run VAD inline, and save speech segments + raw audio to disk.
"""

from __future__ import annotations

import logging
from datetime import datetime, timezone
from typing import TYPE_CHECKING

from discord.sinks import Sink, Filters

from audio.storage import save_pcm_as_wav
from audio.vad import SpeechSegmenter
from config import MIN_SPEECH_DURATION, SAMPLE_RATE, PCM_SAMPLE_WIDTH

if TYPE_CHECKING:
    from commands.voice import VoiceCommandDetector

log = logging.getLogger(__name__)


class UserAudioSink(Sink):
    """Custom audio sink that captures per-user audio streams.

    For each user, maintains a VAD segmenter and saves:
    - All raw audio to disk (periodically flushed)
    - Speech segments separately for transcription
    """

    def __init__(
        self,
        bot,
        voice_detector: VoiceCommandDetector | None = None,
        *,
        filters=None,
    ):
        super().__init__(filters=filters)
        self.bot = bot
        self.voice_detector = voice_detector
        self._segmenters: dict[int, SpeechSegmenter] = {}
        self._raw_buffers: dict[int, bytearray] = {}
        self._speech_segments: dict[int, list[bytes]] = {}
        self._excluded_users: set[int] = set()
        self._user_names: dict[int, str] = {}

    def _get_segmenter(self, user_id: int) -> SpeechSegmenter:
        if user_id not in self._segmenters:
            self._segmenters[user_id] = SpeechSegmenter()
        return self._segmenters[user_id]

    def _resolve_username(self, user_id: int) -> str:
        """Resolve a user ID to a username via the bot's cache."""
        if user_id in self._user_names:
            return self._user_names[user_id]
        user = self.bot.get_user(user_id)
        name = user.name if user else str(user_id)
        self._user_names[user_id] = name
        return name

    def exclude_user(self, user_id: int) -> None:
        """Stop recording a user (privacy request)."""
        self._excluded_users.add(user_id)
        log.info("User %d excluded from recording", user_id)

    def include_user(self, user_id: int) -> None:
        """Resume recording a user."""
        self._excluded_users.discard(user_id)
        log.info("User %d included in recording", user_id)

    @Filters.container
    def write(self, data: bytes, user: int) -> None:
        """Called by py-cord for each decoded audio packet.

        Parameters
        ----------
        data: raw PCM bytes (stereo, 16-bit, 48kHz)
        user: user ID (snowflake int)
        """
        if user in self._excluded_users:
            return

        username = self._resolve_username(user)

        # Accumulate raw audio
        if user not in self._raw_buffers:
            self._raw_buffers[user] = bytearray()
        self._raw_buffers[user].extend(data)

        # Run VAD
        segmenter = self._get_segmenter(user)
        segments = segmenter.process_chunk(data)

        for segment in segments:
            # Duration check (mono, 16-bit, 48kHz)
            duration = len(segment) / (SAMPLE_RATE * PCM_SAMPLE_WIDTH)
            if duration < MIN_SPEECH_DURATION:
                continue

            if user not in self._speech_segments:
                self._speech_segments[user] = []
            self._speech_segments[user].append(segment)

            # Save speech segment to disk
            save_pcm_as_wav(
                segment,
                username,
                label="speech",
                sample_rate=SAMPLE_RATE,
                channels=1,  # VAD outputs mono
                sample_width=PCM_SAMPLE_WIDTH,
            )
            log.info("Speech segment from %s: %.1fs", username, duration)

    def flush_raw_audio(self) -> dict[str, list]:
        """Save all raw audio buffers to disk and clear them."""
        results: dict[str, list] = {}
        for user_id, buf in self._raw_buffers.items():
            if not buf:
                continue
            username = self._user_names.get(user_id, str(user_id))
            path = save_pcm_as_wav(bytes(buf), username, label="raw")
            results.setdefault(username, []).append(path)
        self._raw_buffers.clear()
        return results

    def get_speech_segments(self, user_id: int | None = None) -> dict[int, list[bytes]]:
        """Get accumulated speech segments."""
        if user_id is not None:
            return {user_id: self._speech_segments.get(user_id, [])}
        return dict(self._speech_segments)

    def clear_speech_segments(self, user_id: int | None = None) -> None:
        """Clear speech segments after processing."""
        if user_id is not None:
            self._speech_segments.pop(user_id, None)
        else:
            self._speech_segments.clear()

    def cleanup(self) -> None:
        """Flush all remaining data and call parent cleanup."""
        # Flush VAD buffers
        for user_id, segmenter in self._segmenters.items():
            remaining = segmenter.flush()
            if remaining:
                username = self._user_names.get(user_id, str(user_id))
                save_pcm_as_wav(
                    remaining,
                    username,
                    label="speech_final",
                    sample_rate=SAMPLE_RATE,
                    channels=1,
                    sample_width=PCM_SAMPLE_WIDTH,
                )

        # Flush raw buffers
        self.flush_raw_audio()

        self._segmenters.clear()
        self._speech_segments.clear()
        log.info("Audio sink cleaned up")

        # Parent cleanup
        super().cleanup()
